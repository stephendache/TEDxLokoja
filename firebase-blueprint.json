{
  "entities": {
    "User": {
      "title": "User",
      "description": "A registered user of the platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "TicketType": {
      "title": "TicketType",
      "description": "A type of ticket available for purchase.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number" },
        "available": { "type": "number" },
        "visibility": { "type": "string", "enum": ["public", "hidden"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "quantity", "available", "createdAt"]
    },
    "TicketPurchase": {
      "title": "TicketPurchase",
      "description": "A record of a ticket purchase.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "ticketTypeId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "success", "failed"] },
        "reference": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "ticketTypeId", "amount", "status", "reference", "createdAt"]
    },
    "Speaker": {
      "title": "Speaker",
      "description": "A speaker for the event.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "bio": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "createdAt"]
    },
    "SpeakerApplication": {
      "title": "SpeakerApplication",
      "description": "An application to speak at the event.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "topic": { "type": "string" },
        "description": { "type": "string" },
        "pastExperience": { "type": "string" },
        "links": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "phone", "topic", "description", "status", "createdAt"]
    },
    "SponsorApplication": {
      "title": "SponsorApplication",
      "description": "An application to sponsor the event.",
      "type": "object",
      "properties": {
        "companyName": { "type": "string" },
        "contactName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "sponsorshipLevel": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "contacted", "confirmed", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["companyName", "contactName", "email", "phone", "sponsorshipLevel", "status", "createdAt"]
    },
    "MerchItem": {
      "title": "MerchItem",
      "description": "A merchandise item available in the store.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number" },
        "available": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "quantity", "available", "category", "createdAt"]
    },
    "MerchOrder": {
      "title": "MerchOrder",
      "description": "A record of a merchandise purchase.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "merchId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "success", "failed"] },
        "reference": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "merchId", "amount", "status", "reference", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/ticketTypes/{ticketTypeId}": {
      "schema": { "$ref": "#/entities/TicketType" },
      "description": "Stores available ticket types."
    },
    "/purchases/{purchaseId}": {
      "schema": { "$ref": "#/entities/TicketPurchase" },
      "description": "Stores ticket purchase records."
    },
    "/speakers/{speakerId}": {
      "schema": { "$ref": "#/entities/Speaker" },
      "description": "Stores speaker profiles."
    },
    "/speakerApplications/{appId}": {
      "schema": { "$ref": "#/entities/SpeakerApplication" },
      "description": "Stores call for speakers applications."
    },
    "/sponsorApplications/{appId}": {
      "schema": { "$ref": "#/entities/SponsorApplication" },
      "description": "Stores sponsorship applications."
    },
    "/merch/{merchId}": {
      "schema": { "$ref": "#/entities/MerchItem" },
      "description": "Stores merchandise inventory."
    },
    "/merchOrders/{orderId}": {
      "schema": { "$ref": "#/entities/MerchOrder" },
      "description": "Stores merchandise purchase records."
    }
  }
}
